<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/day_theme_background"
    tools:context=".activity.BookmarksActivity"
    tools:openDrawer="start">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/background_layout"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:background="@color/day_theme_background"
        android:layout_marginBottom="?android:attr/actionBarSize">

        <Button
            android:id="@+id/background1"
            android:layout_width="0dp"
            android:layout_height="85dp"
            android:layout_marginTop="-4dp"
            android:backgroundTint="@color/day_theme_rectangle"
            android:clickable="false"
            app:cornerRadius="0sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="1"
            app:strokeWidth="0sp" />

        <ImageButton
            android:id="@+id/sidebar_button"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="8dp"
            android:background="#00FFFFFF"
            android:scaleX="2"
            android:scaleY="2"
            app:layout_constraintBottom_toBottomOf="@+id/background1"
            app:layout_constraintStart_toStartOf="@+id/background1"
            app:srcCompat="@drawable/tabs" />

        <ImageButton
            android:id="@+id/page_image"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="8dp"
            android:background="#00FFFFFF"
            android:scaleX="1.5"
            android:scaleY="1.5"
            app:layout_constraintBottom_toBottomOf="@+id/background1"
            app:layout_constraintEnd_toEndOf="@+id/background1"
            app:srcCompat="@drawable/bookmark" />

        <TextView
            android:id="@+id/page_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/bm"
            android:textColor="@color/black"
            android:textSize="26sp"
            app:layout_constraintBottom_toBottomOf="@+id/background1"
            app:layout_constraintEnd_toStartOf="@+id/page_image"
            app:layout_constraintStart_toEndOf="@+id/sidebar_button" />

        <Button
            android:id="@+id/background2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/day_theme_search"
            android:scaleType="fitXY"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.09"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/background1"
            app:layout_constraintWidth_percent="0.9"
            app:strokeColor="@color/black"
            app:strokeWidth="2sp" />

        <ImageView
            android:id="@+id/search_image"
            android:layout_width="44dp"
            android:layout_height="47dp"
            android:layout_marginStart="16dp"
            app:layout_constraintBottom_toBottomOf="@+id/background2"
            app:layout_constraintStart_toStartOf="@+id/background2"
            app:layout_constraintTop_toTopOf="@+id/background2"
            app:srcCompat="@drawable/magnifier" />

        <TextView
            android:id="@+id/search"
            android:layout_width="0dp"
            android:layout_height="35sp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:editable="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:hint="@string/search"
            android:scaleType="fitXY"
            android:singleLine="true"
            android:textColor="@color/black"
            android:textColorHint="@color/gray"
            android:textSize="26sp"
            app:layout_constraintBottom_toBottomOf="@+id/background2"
            app:layout_constraintEnd_toEndOf="@+id/background2"
            app:layout_constraintHorizontal_bias="0.142"
            app:layout_constraintStart_toEndOf="@+id/search_image"
            app:layout_constraintTop_toTopOf="@+id/background2" />

        <ScrollView
            android:id="@+id/mark_scroll"
            android:layout_width="411dp"
            android:layout_height="402dp"
            app:layout_constraintBottom_toTopOf="@+id/background3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.55"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <Button
            android:id="@+id/background3"
            android:layout_width="0sp"
            android:layout_height="80sp"
            android:layout_marginBottom="-3dp"
            android:backgroundTint="@color/day_theme_rectangle"
            android:clickable="false"
            android:scaleType="fitXY"
            app:cornerRadius="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.498"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/selected_background"
            android:layout_width="52dp"
            android:layout_height="54dp"
            android:backgroundTint="@color/day_theme_selection"
            app:cornerRadius="60dp"
            app:layout_constraintBottom_toBottomOf="@+id/bookmarks_button"
            app:layout_constraintEnd_toEndOf="@+id/bookmarks_button"
            app:layout_constraintStart_toStartOf="@+id/bookmarks_button"
            app:layout_constraintTop_toTopOf="@+id/bookmarks_button" />

        <ImageButton
            android:id="@+id/bookmarks_button"
            android:layout_width="50dp"
            android:layout_height="49dp"
            android:layout_marginStart="16dp"
            android:background="#00FFFFFF"
            android:scaleX="1.5"
            android:scaleY="1.5"
            app:layout_constraintBottom_toBottomOf="@+id/background3"
            app:layout_constraintStart_toStartOf="@+id/background3"
            app:layout_constraintTop_toTopOf="@+id/background3"
            app:srcCompat="@drawable/bookmark" />

        <ImageButton
            android:id="@+id/main_button"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="#00FFFFFF"
            android:scaleX="2.2"
            android:scaleY="2.2"
            app:layout_constraintBottom_toBottomOf="@+id/background3"
            app:layout_constraintEnd_toStartOf="@+id/book_list_button"
            app:layout_constraintStart_toEndOf="@+id/bookmarks_button"
            app:layout_constraintTop_toTopOf="@+id/background3"
            app:srcCompat="@drawable/house" />

        <ImageButton
            android:id="@+id/book_list_button"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="16dp"
            android:background="#00FFFFFF"
            android:scaleX="2"
            android:scaleY="2"
            app:layout_constraintBottom_toBottomOf="@+id/background3"
            app:layout_constraintEnd_toEndOf="@+id/background3"
            app:layout_constraintTop_toTopOf="@+id/background3"
            app:srcCompat="@drawable/list_check" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:visibility="visible"
        app:headerLayout="@layout/activity_header_sidebar"
        app:menu="@menu/sidebar_drawer_menu"
        tools:ignore="MissingConstraints" />

</androidx.drawerlayout.widget.DrawerLayout>